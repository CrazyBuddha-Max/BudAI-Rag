# 2. Python 后端 (Python Backend)
# ==========================================
**/__pycache__/
**/*.py[cod]
**/*.pyc
**/*.so
**/.Python
**/.venv/
**/venv/
**/env/
**/ENV/

# 依赖与打包
**/build/
**/dist/
**/*.egg-info/
**/.eggs/
**/.installed.cfg
**/.installed.cfg

# 测试与质量检查
**/.pytest_cache/
**/.ruff_cache/
**/.mypy_cache/
**/.tox/
**/.coverage
**/htmlcov/

# uv 包管理器特有
**/.uv/

# ==========================================
# 3. Node.js 前端 (Frontend)
# ==========================================
**/node_modules/
**/logs/
**/*.log
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*
**/.pnpm-debug.log*

# 编译产物
**/dist/
**/dist-ssr/
**/out/
**/.next/
**/.nuxt/

# 浏览器测试缓存 (Playwright/Cypress)
**/test-results/
